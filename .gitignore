# OpenClaw Configuration Files
# IMPORTANT: Never commit sensitive data!

# Authentication and API keys
auth-profiles.json
**/auth-profiles.json
**/*auth*.json

# Local configuration (may contain sensitive data)
openclaw.json
agents/*/agent/config.json

# Logs
*.log
logs/
**/*.log

# Cache and temporary files
cache/
*.tmp
*.temp
.cache/

# Session data
sessions/
*.session

# Database files
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.code-workspace

# Node modules (if using npm for OpenClaw)
node_modules/
package-lock.json

# Python (if using Python scripts)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Backup files
*.backup
*.bak
*.old
backup/

# Personal notes
NOTES.md
TODO.md
notes/

# Telegram bot tokens
telegram-token.txt
*.token

# Keys and certificates
*.key
*.pem
*.crt
*.p12

# MacOS
.AppleDouble
.LSOverride

# Linux
*~
.directory

# Windows
desktop.ini
$RECYCLE.BIN/

# Archives
*.zip
*.tar.gz
*.rar
*.7z
